# Docker Deployment Environment Variables
# Copy to .env for Docker Compose

# Database Configuration
DB_USER=pantry
DB_PASSWORD=pantry_pass
DB_NAME=pantry_db

# Vision API
VISION_PROVIDER=openclaw
OPENCLAW_VISION_URL=http://172.16.1.1:18790/analyze
OPENCLAW_GATEWAY_TOKEN_FILE=/run/secrets/openclaw_gateway_token
OPENCLAW_VISION_MODEL=openai/gpt-5.4-mini
OPENCLAW_TIMEOUT=120
NVIDIA_NIM_API_KEY=
NVIDIA_MODEL=meta/llama-3.2-11b-vision-instruct
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Backend Configuration
LOG_LEVEL=INFO
DEBUG=false

# Storage Configuration
STORAGE_PATH=/app/storage
IMAGE_RETENTION_DAYS=30
MAX_STORAGE_MB=5000

# Celery Configuration
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Redis Configuration
REDIS_URL=redis://redis:6379/0
